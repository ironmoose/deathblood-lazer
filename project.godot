; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited just fine manually.

config_version=5

[application]

config/name="Golden Brawl"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6")

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[layer_names]

2d_physics/layer_1="World"
2d_physics/layer_2="Player"
2d_physics/layer_3="Enemy"
2d_physics/layer_4="PlayerHurtbox"
2d_physics/layer_5="EnemyHurtbox"
2d_physics/layer_6="PlayerHitbox"
2d_physics/layer_7="EnemyHitbox"
2d_physics/layer_8="Pickup"
