; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Golden Brawl"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6")

[autoload]

GameManager="*res://scripts/managers/game_manager.gd"
InputManager="*res://scripts/managers/input_manager.gd"
HitStop="*res://scripts/combat/hitstop.gd"
EnemyGroupManager="*res://scripts/managers/enemy_group_manager.gd"
PauseOverlay="*res://scripts/ui/pause_overlay.gd"
ScreenFX="*res://scripts/combat/screen_fx.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"

