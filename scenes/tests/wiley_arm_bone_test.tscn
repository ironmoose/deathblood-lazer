; Skeleton2D smoke test for the painterly Wiley right arm.
;
; How to run:
;   - In the Godot editor: open this scene and press F6 (Play Scene).
;   - From the CLI:
;       godot --path /home/khildrak/workspaces/deathblood-lazer \
;             res://scenes/tests/wiley_arm_bone_test.tscn
;
; What it shows:
;   A single Bone2D ("ShoulderBone") with the cropped right-arm sprite
;   parented to it. AnimationPlayer autoplays "wave", a 1.5s looping
;   pendulum rotation between -0.4 and +0.4 rad with cubic interpolation.

[gd_scene load_steps=4 format=3 uid="uid://dblzwileyarmtest"]

[ext_resource type="Texture2D" path="res://assets/sprites/characters/wiley/painterly/right_arm.png" id="1_arm_tex"]

[sub_resource type="Animation" id="Animation_wave"]
resource_name = "wave"
length = 1.5
loop_mode = 1
tracks/0/type = "value"
tracks/0/imported = false
tracks/0/enabled = true
tracks/0/path = NodePath("Skeleton/ShoulderBone:rotation")
tracks/0/interp = 2
tracks/0/loop_wrap = true
tracks/0/keys = {
"times": PackedFloat32Array(0, 0.75, 1.5),
"transitions": PackedFloat32Array(1, 1, 1),
"update": 0,
"values": [-0.4, 0.4, -0.4]
}

[sub_resource type="AnimationLibrary" id="AnimationLibrary_default"]
_data = {
"wave": SubResource("Animation_wave")
}

[node name="WileyArmBoneTest" type="Node2D"]

[node name="Background" type="ColorRect" parent="."]
offset_right = 640.0
offset_bottom = 360.0
color = Color(0.133333, 0.133333, 0.133333, 1)

[node name="Camera2D" type="Camera2D" parent="."]
position = Vector2(320, 180)
zoom = Vector2(1, 1)

[node name="Skeleton" type="Skeleton2D" parent="."]
position = Vector2(320, 200)

[node name="ShoulderBone" type="Bone2D" parent="Skeleton"]
rotation = -0.4
auto_calculate_length_and_angle = false
length = 290.0
bone_angle = 1.5707963267948966

[node name="ArmSprite" type="Sprite2D" parent="Skeleton/ShoulderBone"]
texture = ExtResource("1_arm_tex")
centered = false
offset = Vector2(-50, -20)

[node name="AnimPlayer" type="AnimationPlayer" parent="."]
libraries = {
"": SubResource("AnimationLibrary_default")
}
autoplay = "wave"
