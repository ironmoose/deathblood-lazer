# Normalize all text files to LF in the repo, CRLF on Windows checkout
* text=auto eol=lf

# Godot files are always text
*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.godot text eol=lf
*.cfg text eol=lf
*.shader text eol=lf
*.gdshader text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.wav binary
*.ogg binary
*.mp3 binary
*.ttf binary
*.otf binary
